{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true
    },
    "include": [
        "src/global.d.ts",
        "src/**/*.ts"
    ]
}